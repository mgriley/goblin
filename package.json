{
  "name": "goblin",
  "version": "1.0.0",
  "description": "Hierarchical autonomous runtime of Node.js subprocesses (goblins) coordinated via IPC.",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && cp src/functions/worker.mjs dist/functions/worker.mjs && cp src/functions/sys.mjs dist/functions/sys.mjs && npm run build:sites",
    "build:sites": "node src/inspector/build-site.mjs && node src/visualizer/build-site.mjs",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "inspector": "node src/inspector/build-site.mjs --dev && tsx src/inspector/main.ts",
    "visualizer": "node src/visualizer/build-site.mjs --dev && tsx src/visualizer/main.ts",
    "typecheck": "npm run typecheck:node && npm run typecheck:site",
    "typecheck:node": "tsc --noEmit",
    "typecheck:site": "tsc -p tsconfig.site.json",
    "test": "node --import tsx --test $(find src -name '*_test.ts')",
    "test:e2e": "node --import tsx tests/run.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
