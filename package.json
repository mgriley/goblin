{
  "name": "elf-army",
  "version": "1.0.0",
  "description": "Hierarchical autonomous runtime of Node.js subprocesses (elves) coordinated via IPC.",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && cp src/functions/worker.mjs dist/functions/worker.mjs",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test $(find src -name '*_test.ts')"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
